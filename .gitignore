# Local overrides — anything *.local.* is yours alone, not for the public repo
# (…but *.local.example.* templates ARE committed, so the shape is documented)
*.local.*
!*.local.example.*
settings.local.json

# Secrets — never track. The Slack bot token lives in ~/.codex/config.toml and
# ~/.claude/settings.json (secret-managed, env-var injected), never in this repo.
# Belt-and-braces against an accidental copy landing here (fleet-config#74);
# the real wire is the secret_scan_guard hook, which blocks the commit itself.
.env
*.env
config.toml
.codex/

# Installer state (records which junctions/symlinks were created)
.fleet-config-installed.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# App-launcher scratch (pasted images, transient run artifacts)
.launcher-tmp/

# Skill scratch — any session's transient digest/ledger working files. Skills
# write to the system temp dir, but guard against a stray relative-path write
# landing in the repo (a concurrent session once dropped these here).
tmp/
.tmp-*

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Runtime logs (hook/automation output)
logs/

# Fleet Board session state (fleet-config#91) — written at runtime by
# hooks/session_state.py; lands in the tree because ~/.claude/hooks is a
# junction into this repo.
hooks/state/
