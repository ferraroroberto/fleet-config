# Local overrides — anything *.local.* is yours alone, not for the public repo
*.local.*
settings.local.json

# Secrets — never track. The Slack bot token lives in ~/.codex/config.toml and
# ~/.claude/settings.json (secret-managed, env-var injected), never in this repo.
# Belt-and-braces against an accidental copy landing here (claude-config#74);
# the real wire is the secret_scan_guard hook, which blocks the commit itself.
.env
*.env
config.toml
.codex/

# Installer state (records which junctions/symlinks were created)
.claude-config-installed.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# App-launcher scratch (pasted images, transient run artifacts)
.launcher-tmp/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Runtime logs (hook/automation output)
logs/
